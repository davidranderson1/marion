<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Dial Caliper Training | FluidSeal AB</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
body{background:#000;font-family:'Inter',sans-serif;overflow:hidden;width:100vw;height:100vh;display:flex;align-items:center;justify-content:center}

/* ── STAGE ── */
#stage{
  width:960px;height:540px;position:relative;overflow:hidden;
  background:#0f1923;
}

/* ── SCENES ── */
.scene{
  position:absolute;inset:0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity .6s ease;
}
.scene.active{opacity:1;pointer-events:all;}

/* ── PROGRESS BAR ── */
#progress-bar{
  position:absolute;bottom:0;left:0;height:3px;
  background:linear-gradient(90deg,#c8222a,#ff6b6b);
  width:0%;z-index:100;transition:width .1s linear;
}

/* ── SCENE 0: INTRO ── */
#s0{background:linear-gradient(135deg,#0f1923 0%,#1a2e3f 60%,#0d1e2e 100%);}
#s0 .bg-circle{
  position:absolute;width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle,rgba(200,34,42,.15) 0%,transparent 70%);
  top:-100px;right:-100px;
}
#s0 .logo-wrap{display:flex;align-items:center;gap:14px;margin-bottom:28px;}
#s0 .logo-dot{
  width:52px;height:52px;border-radius:50%;background:#c8222a;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
#s0 .brand{font-size:28px;font-weight:800;color:#fff;letter-spacing:.5px;}
#s0 .brand-sub{font-size:12px;color:#4a7090;letter-spacing:2px;text-transform:uppercase;margin-top:2px;}
#s0 h1{font-size:48px;font-weight:800;color:#fff;text-align:center;line-height:1.1;margin-bottom:16px;}
#s0 h1 span{color:#e8464a;}
#s0 p{font-size:17px;color:#5a8090;text-align:center;max-width:520px;line-height:1.6;}
#s0 .badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(200,34,42,.15);border:1px solid rgba(200,34,42,.35);
  color:#e87a7e;font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;
  padding:7px 18px;border-radius:20px;margin-bottom:24px;
}

/* ── SCENE 1: PARTS OVERVIEW ── */
#s1{background:#0f1923;flex-direction:column;}
#s1 .section-tag{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#c8222a;margin-bottom:12px;}
#s1 h2{font-size:34px;font-weight:800;color:#fff;margin-bottom:32px;text-align:center;}
#s1 .caliper-wrap{position:relative;width:860px;max-width:90%;}
#s1 .caliper-wrap img{width:100%;border-radius:8px;box-shadow:0 8px 40px rgba(0,0,0,.5);}
/* label chips */
.chip{
  position:absolute;
  background:#0f1923;border:1px solid #c8222a;
  color:#fff;font-size:11px;font-weight:600;
  padding:4px 10px;border-radius:4px;white-space:nowrap;
  opacity:0;transform:scale(.8);
  transition:opacity .4s ease, transform .4s ease;
}
.chip.show{opacity:1;transform:scale(1);}
.chip::after{content:'';position:absolute;background:#c8222a;}
/* dot on image */
.pdot{
  position:absolute;width:9px;height:9px;border-radius:50%;
  background:#fff;border:2px solid #c8222a;
  transform:translate(-50%,-50%);
  opacity:0;transition:opacity .3s ease;
  box-shadow:0 0 0 3px rgba(200,34,42,.3);
}
.pdot.show{opacity:1;}

/* ── SCENE 2: HOW TO READ ── */
#s2{background:#0d1e2e;}
#s2 .read-layout{display:flex;gap:50px;align-items:center;width:860px;}
#s2 .read-left{flex:1;}
#s2 .read-right{width:300px;flex-shrink:0;}
#s2 .step-row{
  display:flex;align-items:flex-start;gap:16px;
  margin-bottom:22px;
  opacity:0;transform:translateX(-24px);
  transition:opacity .5s ease,transform .5s ease;
}
#s2 .step-row.show{opacity:1;transform:translateX(0);}
#s2 .snum{
  width:36px;height:36px;border-radius:50%;background:#c8222a;
  color:#fff;font-size:15px;font-weight:800;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
#s2 .stxt h3{font-size:15px;font-weight:700;color:#fff;margin-bottom:3px;}
#s2 .stxt p{font-size:12.5px;color:#5a8090;line-height:1.5;}
#s2 .formula{
  background:#0f1923;border-left:3px solid #c8222a;
  color:#7ec8f0;font-family:monospace;font-size:12px;
  padding:6px 12px;border-radius:0 4px 4px 0;margin-top:8px;
}
/* reading display */
.read-display{background:#0f1923;border-radius:10px;padding:22px;border:1px solid #1a3048;}
.read-display .rd-label{font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#3a6080;margin-bottom:6px;}
.read-display .rd-val{font-family:monospace;font-size:28px;font-weight:700;color:#7ec8f0;margin-bottom:16px;}
.read-display .rd-total{background:#c8222a;border-radius:8px;padding:14px;text-align:center;margin-top:10px;}
.read-display .rd-total .lbl{font-size:10px;color:rgba(255,255,255,.6);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:4px;}
.read-display .rd-total .val{font-family:monospace;font-size:30px;font-weight:800;color:#fff;letter-spacing:2px;}

/* ── SCENE 3: TIPS ── */
#s3{background:#0f1923;}
#s3 h2{font-size:32px;font-weight:800;color:#fff;margin-bottom:28px;text-align:center;}
#s3 .tips-row{display:flex;gap:18px;width:860px;}
.tip-box{
  flex:1;background:#0d1e2e;border-radius:10px;padding:22px 18px;
  border-top:3px solid #c8222a;
  opacity:0;transform:translateY(20px);
  transition:opacity .4s ease,transform .4s ease;
}
.tip-box.show{opacity:1;transform:translateY(0);}
.tip-box .ticon{font-size:28px;margin-bottom:10px;}
.tip-box h3{font-size:14px;font-weight:700;color:#fff;margin-bottom:6px;}
.tip-box p{font-size:12px;color:#4a7090;line-height:1.55;}

/* ── SCENE 4: CTA ── */
#s4{background:linear-gradient(135deg,#0f1923 0%,#1a1215 100%);}
#s4 .bg-glow{
  position:absolute;width:500px;height:500px;border-radius:50%;
  background:radial-gradient(circle,rgba(200,34,42,.2) 0%,transparent 70%);
  top:50%;left:50%;transform:translate(-50%,-50%);
}
#s4 h2{font-size:42px;font-weight:800;color:#fff;text-align:center;line-height:1.15;margin-bottom:16px;position:relative;}
#s4 h2 span{color:#e8464a;}
#s4 .sub{font-size:16px;color:#4a7090;text-align:center;margin-bottom:32px;position:relative;}
#s4 .cta-btn{
  background:#c8222a;color:#fff;font-size:15px;font-weight:700;
  padding:14px 36px;border-radius:6px;border:none;cursor:pointer;
  text-decoration:none;display:inline-block;position:relative;
  letter-spacing:.3px;
}
#s4 .cta-btn:hover{background:#a81a20;}
#s4 .url{font-size:12px;color:#2a5070;margin-top:20px;letter-spacing:1px;position:relative;}
#s4 .logo-small{
  position:absolute;top:28px;left:32px;
  display:flex;align-items:center;gap:10px;
}
#s4 .logo-small .dot{
  width:32px;height:32px;border-radius:50%;background:#c8222a;
  display:flex;align-items:center;justify-content:center;
}
#s4 .logo-small .name{font-size:14px;font-weight:700;color:#fff;}

/* ── CONTROLS ── */
#controls{
  position:absolute;bottom:12px;right:16px;
  display:flex;gap:8px;z-index:200;
}
#controls button{
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);
  color:#fff;font-size:12px;font-weight:600;padding:6px 14px;border-radius:4px;
  cursor:pointer;transition:background .15s;
}
#controls button:hover{background:rgba(255,255,255,.16);}

/* ── SCENE INDICATOR ── */
#dots{
  position:absolute;bottom:14px;left:50%;transform:translateX(-50%);
  display:flex;gap:6px;z-index:200;
}
.dot-ind{
  width:6px;height:6px;border-radius:50%;
  background:rgba(255,255,255,.2);transition:background .3s;
}
.dot-ind.on{background:#c8222a;}

/* animations */
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
.fade-up{animation:fadeUp .7s ease forwards;}
.fade-up.d1{animation-delay:.2s;opacity:0;}
.fade-up.d2{animation-delay:.5s;opacity:0;}
.fade-up.d3{animation-delay:.8s;opacity:0;}
.fade-up.d4{animation-delay:1.1s;opacity:0;}
</style>
</head>
<body>
<div id="stage">
  <div id="progress-bar"></div>

  <!-- ═══ SCENE 0: INTRO ═══ -->
  <div class="scene active" id="s0">
    <div class="bg-circle"></div>
    <div class="logo-wrap fade-up d1">
      <div class="logo-dot">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
          <path d="M12 2C12 2 5 9.5 5 14.5C5 18.09 8.13 21 12 21C15.87 21 19 18.09 19 14.5C19 9.5 12 2 12 2Z" fill="white"/>
          <path d="M9 15.5C9 13.5 11 11 12 10C13 11 15 13.5 15 15.5C15 17.16 13.66 18.5 12 18.5C10.34 18.5 9 17.16 9 15.5Z" fill="#c8222a"/>
        </svg>
      </div>
      <div>
        <div class="brand">FluidSeal AB</div>
        <div class="brand-sub">Edmonton · Sealing Solutions</div>
      </div>
    </div>
    <div class="badge fade-up d2">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      Staff Training Program
    </div>
    <h1 class="fade-up d3">Dial Caliper<br><span>Training Guide</span></h1>
    <p class="fade-up d4">Master the Mitutoyo 505 — anatomy, reading, and best practices for precision seal measurement.</p>
  </div>

  <!-- ═══ SCENE 1: PARTS ═══ -->
  <div class="scene" id="s1">
    <div class="section-tag">Module 1</div>
    <h2>Know Your Caliper</h2>
    <div class="caliper-wrap" id="caliper-wrap">
      <img id="caliper-img" src="data:image/png;base64," alt="Mitutoyo dial caliper">
      <!-- dots -->
      <div class="pdot" id="d-ext"   style="left:9.6%;top:87%"></div>
      <div class="pdot" id="d-int"   style="left:10.8%;top:12%"></div>
      <div class="pdot" id="d-dial"  style="left:22.9%;top:49%"></div>
      <div class="pdot" id="d-beam"  style="left:66%;top:44%"></div>
      <div class="pdot" id="d-depth" style="left:97%;top:55%"></div>
      <div class="pdot" id="d-thumb" style="left:31.2%;top:68%"></div>
      <!-- chips -->
      <div class="chip" id="c-ext"   style="left:0%;top:92%">External Jaws</div>
      <div class="chip" id="c-int"   style="left:2%;top:2%">Internal Jaws</div>
      <div class="chip" id="c-dial"  style="left:18%;top:-8%">Dial Face</div>
      <div class="chip" id="c-beam"  style="left:58%;top:-8%">Scale Beam</div>
      <div class="chip" id="c-depth" style="left:86%;top:-8%">Depth Rod</div>
      <div class="chip" id="c-thumb" style="left:27%;top:105%">Thumb Wheel</div>
    </div>
  </div>

  <!-- ═══ SCENE 2: HOW TO READ ═══ -->
  <div class="scene" id="s2">
    <div class="read-layout">
      <div class="read-left">
        <div style="font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#c8222a;margin-bottom:10px;">Module 2</div>
        <h2 style="font-size:30px;font-weight:800;color:#fff;margin-bottom:24px;">How to Read<br>a Dial Caliper</h2>
        <div class="step-row" id="sr1">
          <div class="snum">1</div>
          <div class="stxt"><h3>Zero the caliper</h3><p>Close jaws fully. Rotate bezel nut until needle reads exactly 0.</p></div>
        </div>
        <div class="step-row" id="sr2">
          <div class="snum">2</div>
          <div class="stxt"><h3>Read the beam</h3><p>Find the last inch mark the sliding jaw has passed.</p><div class="formula">e.g. → 1.200″</div></div>
        </div>
        <div class="step-row" id="sr3">
          <div class="snum">3</div>
          <div class="stxt"><h3>Read the dial</h3><p>Each of 100 divisions = 0.001″. Needle at 35 = 0.035″</p><div class="formula">e.g. → 0.035″</div></div>
        </div>
        <div class="step-row" id="sr4">
          <div class="snum">4</div>
          <div class="stxt"><h3>Add together</h3><p>Beam + Dial = total measurement.</p></div>
        </div>
      </div>
      <div class="read-right">
        <div class="read-display">
          <div class="rd-label">Beam Scale</div>
          <div class="rd-val" id="beam-val">1.200″</div>
          <div style="height:1px;background:#1a3048;margin:8px 0;"></div>
          <div class="rd-label">Dial Reading</div>
          <div class="rd-val" id="dial-val">0.035″</div>
          <!-- SVG mini dial -->
          <svg viewBox="0 0 120 120" style="width:90px;display:block;margin:4px auto 10px;">
            <circle cx="60" cy="60" r="54" fill="#0a1620" stroke="#1a3048" stroke-width="1"/>
            <circle cx="60" cy="60" r="48" fill="#f4f0e8"/>
            <g stroke="#1a2028" stroke-width="0.6">
              <line x1="60" y1="13" x2="60" y2="21"/>
              <line x1="60" y1="99" x2="60" y2="107"/>
              <line x1="13" y1="60" x2="21" y2="60"/>
              <line x1="99" y1="60" x2="107" y2="60"/>
            </g>
            <text x="60" y="27" text-anchor="middle" font-size="8" fill="#1a2028" font-weight="bold" font-family="Arial">0</text>
            <text x="94" y="64" text-anchor="middle" font-size="7" fill="#1a2028" font-family="Arial">25</text>
            <text x="60" y="99" text-anchor="middle" font-size="7" fill="#1a2028" font-family="Arial">50</text>
            <text x="28" y="64" text-anchor="middle" font-size="7" fill="#1a2028" font-family="Arial">75</text>
            <line id="needle" x1="60" y1="60" x2="60" y2="16" stroke="#c8222a" stroke-width="2" stroke-linecap="round"/>
            <line x1="60" y1="60" x2="54" y2="70" stroke="#8a1818" stroke-width="2.5" stroke-linecap="round"/>
            <circle cx="60" cy="60" r="3.5" fill="#404a58"/>
          </svg>
          <div class="rd-total">
            <div class="lbl">Total</div>
            <div class="val">1.235″</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ SCENE 3: TIPS ═══ -->
  <div class="scene" id="s3">
    <div style="font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#c8222a;margin-bottom:12px;">Best Practices</div>
    <h2>Tips for Accurate Results</h2>
    <div class="tips-row">
      <div class="tip-box" id="t1">
        <div class="ticon">⚪</div>
        <h3>Always Zero First</h3>
        <p>Close jaws fully and check dial reads 0. Rotate bezel nut if needed before every measurement.</p>
      </div>
      <div class="tip-box" id="t2">
        <div class="ticon">🧹</div>
        <h3>Clean the Jaws</h3>
        <p>Wipe with a lint-free cloth. Even a single metal chip can add 0.005″ of error.</p>
      </div>
      <div class="tip-box" id="t3">
        <div class="ticon">📐</div>
        <h3>Stay Perpendicular</h3>
        <p>Hold the caliper square to the part. Angled readings are always too large.</p>
      </div>
      <div class="tip-box" id="t4">
        <div class="ticon">📦</div>
        <h3>Store Correctly</h3>
        <p>Leave a small jaw gap when storing. Keep in the case, away from magnets.</p>
      </div>
    </div>
  </div>

  <!-- ═══ SCENE 4: CTA ═══ -->
  <div class="scene" id="s4">
    <div class="bg-glow"></div>
    <div class="logo-small">
      <div class="dot">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M12 2C12 2 5 9.5 5 14.5C5 18.09 8.13 21 12 21C15.87 21 19 18.09 19 14.5C19 9.5 12 2 12 2Z" fill="white"/>
          <path d="M9 15.5C9 13.5 11 11 12 10C13 11 15 13.5 15 15.5C15 17.16 13.66 18.5 12 18.5C10.34 18.5 9 17.16 9 15.5Z" fill="#c8222a"/>
        </svg>
      </div>
      <div class="name">FluidSeal AB</div>
    </div>
    <h2 class="fade-up d1">Ready to Measure<br><span>with Confidence?</span></h2>
    <p class="sub fade-up d2">Complete the full training module — including parts quiz and worked examples.</p>
    <a href="fluidseal_training.html" class="cta-btn fade-up d3">Open Full Training Guide →</a>
    <div class="url fade-up d4">fluidsealab.com · Precision Tools Training Series</div>
  </div>

  <!-- indicator dots -->
  <div id="dots">
    <div class="dot-ind on" data-i="0"></div>
    <div class="dot-ind" data-i="1"></div>
    <div class="dot-ind" data-i="2"></div>
    <div class="dot-ind" data-i="3"></div>
    <div class="dot-ind" data-i="4"></div>
  </div>

  <!-- controls -->
  <div id="controls">
    <button onclick="prevScene()">◀ Prev</button>
    <button id="play-btn" onclick="togglePlay()">⏸ Pause</button>
    <button onclick="nextScene()">Next ▶</button>
  </div>
</div>

<script>
// ── TIMING (ms per scene) — total ~38 seconds
const DURATIONS = [6500, 9000, 10000, 7000, 6000];
const TOTAL = DURATIONS.reduce((a,b)=>a+b,0);

let currentScene = 0;
let elapsed = 0;
let playing = true;
let rafId = null;
let lastTime = null;
let sceneStart = 0;

const scenes = [
  document.getElementById('s0'),
  document.getElementById('s1'),
  document.getElementById('s2'),
  document.getElementById('s3'),
  document.getElementById('s4'),
];
const bar = document.getElementById('progress-bar');
const dots = document.querySelectorAll('.dot-ind');

// ── SCENE ENTER HOOKS ──────────────────────────────────────────
function enterScene(i) {
  scenes.forEach((s,j)=>{s.classList.toggle('active',j===i);});
  dots.forEach((d,j)=>{d.classList.toggle('on',j===i);});

  if(i===1) animateParts();
  if(i===2) animateRead();
  if(i===3) animateTips();
}

// Scene 1 — stagger part labels
function animateParts(){
  const pairs = [
    ['d-ext','c-ext'],['d-int','c-int'],['d-dial','c-dial'],
    ['d-beam','c-beam'],['d-depth','c-depth'],['d-thumb','c-thumb'],
  ];
  pairs.forEach(([did,cid],i)=>{
    setTimeout(()=>{
      document.getElementById(did).classList.add('show');
      setTimeout(()=>document.getElementById(cid).classList.add('show'),180);
    }, 400 + i*1100);
  });
}

// Scene 2 — stagger steps + animate needle
function animateRead(){
  ['sr1','sr2','sr3','sr4'].forEach((id,i)=>{
    setTimeout(()=>document.getElementById(id).classList.add('show'), 300+i*1400);
  });
  // animate needle from 0 to 35 divisions
  const needle = document.getElementById('needle');
  let div = 0;
  const target = 35;
  const interval = setInterval(()=>{
    div += 1;
    if(div > target){ clearInterval(interval); return; }
    const angle = (div/100)*360 - 90; // degrees
    const rad = angle * Math.PI/180;
    const r = 44;
    const x2 = 60 + r*Math.cos(rad);
    const y2 = 60 + r*Math.sin(rad);
    needle.setAttribute('x2',x2.toFixed(1));
    needle.setAttribute('y2',y2.toFixed(1));
  }, 60);
}

// Scene 3 — stagger tip cards
function animateTips(){
  ['t1','t2','t3','t4'].forEach((id,i)=>{
    setTimeout(()=>document.getElementById(id).classList.add('show'), 300+i*900);
  });
}

// ── PLAYBACK ENGINE ────────────────────────────────────────────
function resetSceneAnimations(i){
  if(i===1){
    document.querySelectorAll('.pdot,.chip').forEach(el=>el.classList.remove('show'));
  }
  if(i===2){
    ['sr1','sr2','sr3','sr4'].forEach(id=>document.getElementById(id).classList.remove('show'));
    const needle = document.getElementById('needle');
    needle.setAttribute('x2','60'); needle.setAttribute('y2','16');
  }
  if(i===3){
    ['t1','t2','t3','t4'].forEach(id=>document.getElementById(id).classList.remove('show'));
  }
}

function goToScene(i){
  if(i<0) i=0;
  if(i>=scenes.length) i=scenes.length-1;
  resetSceneAnimations(currentScene);
  currentScene = i;
  sceneStart = elapsed;
  enterScene(i);
}

function nextScene(){
  if(currentScene < scenes.length-1) goToScene(currentScene+1);
}
function prevScene(){
  if(currentScene > 0) goToScene(currentScene-1);
}

function togglePlay(){
  playing = !playing;
  document.getElementById('play-btn').textContent = playing ? '⏸ Pause' : '▶ Play';
  if(playing){ lastTime = null; rafId = requestAnimationFrame(tick); }
  else{ cancelAnimationFrame(rafId); }
}

function tick(ts){
  if(!playing) return;
  if(lastTime===null){ lastTime=ts; }
  const dt = ts - lastTime; lastTime = ts;
  elapsed += dt;

  // progress bar
  bar.style.width = Math.min(100,(elapsed/TOTAL)*100)+'%';

  // check scene advance
  const sceneElapsed = elapsed - sceneStart;
  if(sceneElapsed >= DURATIONS[currentScene]){
    if(currentScene < scenes.length-1){
      goToScene(currentScene+1);
    } else {
      // loop back
      elapsed = 0; sceneStart = 0;
      goToScene(0);
    }
  }
  rafId = requestAnimationFrame(tick);
}

// ── START ──────────────────────────────────────────────────────
enterScene(0);
lastTime = null;
rafId = requestAnimationFrame(tick);
</script>
</body>
</html>