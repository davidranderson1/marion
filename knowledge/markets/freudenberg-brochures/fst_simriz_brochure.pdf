                        <label class="mb-0" for="Password_5adf3fa2-dff2-429e-8666-56b3179f5754">Password*</label>
                        <input id="Password_5adf3fa2-dff2-429e-8666-56b3179f5754" name="Password" type="password" placeholder="" x-init="registerField(['required'], {required: 'Please enter your password'})" x-model.lazy="fields.Password.value" :class="fields.Password?.validation.error && 'error'" @focusout="validateField('Password')" :type="passwordType"><template x-if="fields.Password?.validation.error"><div class="error-list"><span x-text="fields.Password.validation.error"></span></div></template>
                        <button class="password-toggle__button" type="button" @click="togglePassword" :aria-label="passwordType === 'password' ? 'Show password in plain text' : 'Hide password'">
